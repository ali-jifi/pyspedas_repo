# multi probe esa ion energy flux stack plot, loads peif_en_eflux from all five probes for a single day
# plots one panel per probe with shared time axis and matched color scale

import os
import pyspedas
from pyspedas.projects import themis
from pyspedas import tplot, options, tplot_options, data_exists

# config
TRANGE = ['2009-02-27', '2009-02-28'] 
PROBES = ['a', 'b', 'c', 'd', 'e']
DATA_DIR = r'C:\Users\aliji\Documents\Coding\Research\UTA\esa_plotting\data'
OUT_PNG = 'multi_probe_eflux'

os.environ['THM_DATA_DIR'] = DATA_DIR


themis.esa(
    probe=PROBES,
    trange=TRANGE,
    level='l2',
    notplot=False,
    time_clip=True,
)

# build var list in probe order
vars_to_plot = [f'th{p}_peif_en_eflux' for p in PROBES]

# filter out any probes that did not return data 
loaded = [v for v in vars_to_plot if data_exists(v)]
missing = set(vars_to_plot) - set(loaded)
if missing:
    print(f'[WARN] no data for: {missing}')

# match color scale across probes so panels are comparable and visually look good
ZMIN, ZMAX = 1e3, 1e8 
for v in loaded:
    options(v, 'zlog', 1)
    options(v, 'ylog', 1)
    options(v, 'ztitle', 'eflux\n[eV/cm^2-s-sr-eV]')
    options(v, 'ytitle', f'{v.split("_")[0].upper()}\nEnergy [eV]')
    options(v, 'zrange', [ZMIN, ZMAX])

tplot_options('title', f'THEMIS ESA ion eflux {TRANGE[0]}')
tplot_options('vertical_spacing', 0.05)

# save to png
tplot(
    loaded,
    save_png=OUT_PNG,
    display=False,
)

print(f'[OK] wrote {OUT_PNG}.png with {len(loaded)} panels')